# Database (Neon)
STRIPE_SERVICE_DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Authentication (service-to-service)
STRIPE_SERVICE_API_KEY=shared-secret-for-service-to-service-auth
# Note: the Stripe webhook signing secret is NOT an env var — it's resolved
# at runtime from key-service via GET /keys/platform/stripe-webhook/decrypt.

# Key Service (per-org Stripe key resolution + platform key for event poller)
KEY_SERVICE_URL=https://key.mcpfactory.org
KEY_SERVICE_API_KEY=your-key-service-api-key

# Client Service (resolves end-user email + name from x-user-id, stamped on the
# Stripe customer at POST /v1/customers so the customer is born with an email)
CLIENT_SERVICE_URL=https://client.mcpfactory.org
CLIENT_SERVICE_API_KEY=your-client-service-api-key

# Set to "false" to disable the in-process event poller (useful on non-leader instances when scaled out)
RUN_EVENT_POLLER=true

# Server
PORT=3011
