# Database (Neon)
STRIPE_SERVICE_DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Stripe webhook signing secret (for /v1/webhooks signature verification)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Authentication (service-to-service)
STRIPE_SERVICE_API_KEY=shared-secret-for-service-to-service-auth

# Key Service (per-org Stripe key resolution)
KEY_SERVICE_URL=https://key.mcpfactory.org
KEY_SERVICE_API_KEY=your-key-service-api-key

# Event poller — identity used to resolve the platform Stripe key for the 5-min reconciliation poll
PLATFORM_ORG_ID=00000000-0000-0000-0000-000000000000
PLATFORM_USER_ID=00000000-0000-0000-0000-000000000000

# Set to "false" to disable the in-process event poller (useful on non-leader instances when scaled out)
RUN_EVENT_POLLER=true

# Server
PORT=3011
